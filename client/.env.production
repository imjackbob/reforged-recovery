# Production build settings (loaded automatically by `vite build`).
#
# DEMO / PREVIEW deploy: this is a frontend-only build with no backend, so forms
# run in "preview mode" — they validate and show a success state but do NOT
# submit anywhere. Once the .NET API is deployed (Option B), set this to false
# (or delete this file) and set VITE_API_BASE_URL to the API's URL.
VITE_DEMO_MODE=true
VITE_API_BASE_URL=
