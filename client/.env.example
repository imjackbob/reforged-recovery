# Client environment variables (Vite). Copy to `.env` for local overrides.
# All client-exposed vars MUST be prefixed with VITE_.

# Base URL of the .NET API.
#  - Local dev: leave EMPTY. Vite proxies /api -> http://localhost:5254
#    (see vite.config.js), so same-origin /api calls just work.
#  - Production: set to the deployed API origin IF the API is on a different
#    host than the site, e.g. https://api.reforgedrecovery.org
#    If the API is served under the same domain (reverse proxy), leave EMPTY.
VITE_API_BASE_URL=
